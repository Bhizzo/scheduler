# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/meeting_scheduler"

# NextAuth — generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-me-with-a-long-random-string"
NEXTAUTH_URL="http://localhost:3000"

# Initial assistant account (created by `pnpm db:seed`)
SEED_ASSISTANT_PHONE="+265999000000"
SEED_ASSISTANT_NAME="Assistant"
SEED_ASSISTANT_PASSWORD="change-me-on-first-login"

# App settings
APP_TIMEZONE="Africa/Blantyre"
